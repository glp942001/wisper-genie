#!/usr/bin/env bash
# Wisper Genie — CLI wrapper
# This script is copied to ~/.local/bin/wisper-genie by the installer.
set -euo pipefail

GENIE_HOME="$HOME/.wisper-genie"
VENV="$GENIE_HOME/.venv"

if [ ! -d "$VENV" ]; then
    echo "Wisper Genie not installed. Run the installer first."
    echo "curl -fsSL https://raw.githubusercontent.com/glp942001/wisper-genie/main/install.sh | bash"
    exit 1
fi

# Activate venv
# shellcheck disable=SC1091
source "$VENV/bin/activate"

# Route subcommands
case "${1:-}" in
    install)
        bash "$GENIE_HOME/scripts/setup_models.sh"
        ;;
    autostart)
        python -m dictation.cli autostart "${@:2}"
        ;;
    metrics)
        python -m dictation.cli metrics
        ;;
    uninstall)
        python -m dictation.cli uninstall
        ;;
    --help|-h)
        echo "Wisper Genie — AI dictation tool"
        echo ""
        echo "Usage:"
        echo "  wisper-genie              Start dictating (hold Right Option to speak)"
        echo "  wisper-genie --verbose    Start with debug output"
        echo "  wisper-genie install      Re-run model setup"
        echo "  wisper-genie autostart    Launch on login"
        echo "  wisper-genie autostart --remove   Stop launching on login"
        echo "  wisper-genie metrics      Show recent routing metrics"
        echo "  wisper-genie uninstall    Remove Wisper Genie from your system"
        echo "  wisper-genie --help       Show this help"
        ;;
    *)
        python -m dictation.app "$@"
        ;;
esac
